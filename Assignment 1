<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FashionHub - Premium Store</title><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet"><style>
*{
  margin:0; padding:0; box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{background:#f5f5f5;}

/* Navbar */
nav{
  display:flex; justify-content:space-between; align-items:center;
  padding:20px 60px; background:white;
  position:sticky; top:0; z-index:1000;
  box-shadow:0 4px 10px rgba(0,0,0,0.05);
}

nav h1{color:#111;}
nav ul{display:flex; gap:25px; list-style:none;}
nav ul li{cursor:pointer; transition:0.3s;}
nav ul li:hover{color:#ff4d6d;}

/* Hero */
.hero{
  height:90vh;
  background:linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1521335629791-ce4aec67dd47') center/cover;
  display:flex; align-items:center; padding:0 60px; color:white;
}

.hero h2{font-size:60px; margin-bottom:20px;}
.hero p{margin-bottom:20px;}

.hero button{
  padding:12px 30px;
  background:#ff4d6d;
  border:none; color:white;
  font-size:16px;
  cursor:pointer;
  border-radius:25px;
  transition:0.3s;
}

.hero button:hover{background:#e63950; transform:scale(1.05);}

/* Categories */
.categories{
  display:flex; gap:20px; padding:40px;
}

.category{
  flex:1;
  height:220px;
  border-radius:15px;
  display:flex; align-items:center; justify-content:center;
  font-size:22px; color:white;
  background:linear-gradient(45deg,#ff4d6d,#ff9a9e);
  cursor:pointer;
  transition:0.3s;
}

.category:hover{transform:scale(1.05);}

/* Products */
.products{padding:40px;}
.products h2{margin-bottom:20px;}

.product-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:25px;
}

.product{
  background:white;
  border-radius:15px;
  overflow:hidden;
  box-shadow:0 10px 20px rgba(0,0,0,0.05);
  transition:0.3s;
}

.product:hover{
  transform:translateY(-10px);
  box-shadow:0 15px 25px rgba(0,0,0,0.1);
}

.product img{
  width:100%; height:250px; object-fit:cover;
}

.product-content{padding:15px; text-align:center;}

.product h3{margin:10px 0;}

.product button{
  padding:10px 20px;
  border:none; background:#111; color:white;
  border-radius:20px;
  cursor:pointer;
  transition:0.3s;
}

.product button:hover{background:#ff4d6d;}

/* Footer */
footer{
  background:#111; color:white;
  text-align:center;
  padding:30px;
  margin-top:40px;
}

</style></head><body><nav>
  <h1>FashionHub</h1>
  <ul>
    <li>Home</li>
    <li>Shop</li>
    <li>Men</li>
    <li>Women</li>
    <li>Contact</li>
  </ul>
</nav><section class="hero">
  <div>
    <h2>Upgrade Your Style</h2>
    <p>Premium fashion collection 2026</p>
    <button onclick="alert('Shop Coming Soon!')">Shop Now</button>
  </div>
</section><section class="categories">
  <div class="category">Men</div>
  <div class="category">Women</div>
  <div class="category">Accessories</div>
</section><section class="products">
  <h2>Trending Products</h2>
  <div class="product-grid"><div class="product">
  <img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab">
  <div class="product-content">
    <h3>T-Shirt</h3>
    <p>₹999</p>
    <button>Add to Cart</button>
  </div>
</div>

<div class="product">
  <img src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b">
  <div class="product-content">
    <h3>Jacket</h3>
    <p>₹2499</p>
    <button>Add to Cart</button>
  </div>
</div>

<div class="product">
  <img src="https://images.unsplash.com/photo-1520975922203-bae1c5f7c17d">
  <div class="product-content">
    <h3>Shoes</h3>
    <p>₹1999</p>
    <button>Add to Cart</button>
  </div>
</div>

<div class="product">
  <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f">
  <div class="product-content">
    <h3>Jeans</h3>
    <p>₹1499</p>
    <button>Add to Cart</button>
  </div>
</div>

  </div>
</section><footer>
  <p>© 2026 FashionHub | Designed for Full Marks 💯</p>
</footer></body>
</html>
